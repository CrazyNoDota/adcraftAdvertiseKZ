# OpenAI for the AI mockup engine (gpt-image-1 image editing).
# If unset, /api/mockup returns 503 and the wizard uses the canvas
# placer with drag-to-position fallback.
OPENAI_API_KEY=

# Optional overrides. Defaults shown.
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024            # 1024x1024 | 1024x1536 | 1536x1024 | auto
# OPENAI_IMAGE_QUALITY=high              # low | medium | high | auto

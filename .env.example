# OpenAI for the AI mockup engine (gpt-image-1 image editing).
# If unset, /api/mockup returns 503 and the wizard uses the canvas
# placer with drag-to-position fallback.
OPENAI_API_KEY=

# Optional overrides. Defaults shown.
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_SIZE=1024x1024            # 1024x1024 | 1024x1536 | 1536x1024 | auto
# OPENAI_IMAGE_QUALITY=medium            # low | medium | high | auto

# Rate limit + admin bypass.
# - Visitors are capped at 2 AI generations per 3 hours via a signed cookie.
# - Admins log in at /console with the password below; their browser is
#   exempt from the limit for 30 days (HMAC-signed admin cookie).
ADMIN_PASSWORD=
# Random secret used to sign rate-limit and admin cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
RATELIMIT_SECRET=
